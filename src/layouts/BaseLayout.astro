---
import '/src/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "An ICAO & EASA Compliant Integrated Management System for Aviation Operators." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="bg-slate-950 text-slate-100 scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | AviaSAFE Systems</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen flex flex-col font-sans antialiased selection:bg-blue-600 selection:text-white">
    <header class="border-b border-slate-800/60 bg-slate-950/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="h-9 w-9 rounded-lg bg-gradient-to-br from-blue-500 to-emerald-500 flex items-center justify-center font-bold text-white shadow-lg shadow-blue-500/20">
            A
          </div>
          <span class="font-bold text-xl tracking-tight bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent">
            AviaSAFE <span class="text-slate-400 font-light text-base">systems</span>
          </span>
        </div>
        <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-300">
          <a href="#architecture" class="hover:text-blue-400 transition-colors">Architecture</a>
          <a href="#modules" class="hover:text-blue-400 transition-colors">Platform Modules</a>
          <a href="https://gsacharya.com" target="_blank" class="text-xs px-3 py-1 rounded-full border border-slate-800 bg-slate-900/50 hover:border-slate-700 text-slate-400 hover:text-slate-200 transition-all">
            Field Notes ↗
          </a>
        </nav>
        <div>
          <a href="mailto:thesafetylayer@gmail.com?subject=AviaSAFE%20Systems%20-%20Early%20Access%20Request" class="text-xs font-semibold bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white px-4 py-2 rounded-lg transition-all shadow-lg shadow-blue-600/10">
            Request Early Access
          </a>
        </div>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="border-t border-slate-900 bg-slate-950 text-xs text-slate-400 py-12">
      <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="text-slate-400">&copy; {new Date().getFullYear()} AviaSAFE Systems. All rights reserved.</div>
        <div class="flex gap-6">
          <a href="/privacy" class="text-slate-400 hover:text-blue-400 transition-colors">Privacy Policy</a>
          <a href="/terms" class="text-slate-400 hover:text-blue-400 transition-colors">Terms of Service</a>
        </div>
      </div>
    </footer>
  </body>
</html>
